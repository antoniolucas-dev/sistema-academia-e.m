{
    "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "rootDir": "./src",
      "outDir": "./dist",
  
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
  
      "moduleResolution": "node",
      "types": ["node"],
      "forceConsistentCasingInFileNames": true
    },
  
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }